# ERCOT public API credentials
# Sign up at https://apiexplorer.ercot.com/
ERCOT_API_USERNAME=
ERCOT_API_PASSWORD=
ERCOT_API_SUBSCRIPTION_KEY=

# US EIA (gas prices)
# Get a key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# NOAA requires a contact user-agent string ("app-name contact@email")
NOAA_USER_AGENT=edgeflux-ai your-email@example.com
